{
  "entities": {
    "Medicine": {
      "title": "Medicine",
      "description": "A medicine entry in the user's vault",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "dosage": { "type": "string" },
        "expirationDate": { "type": "string", "format": "date" },
        "usageInstructions": { "type": "string" },
        "createdAt": { "type": "number" },
        "userId": { "type": "string" },
        "capturedImage": { "type": "string" },
        "quantity": { "type": "number" },
        "taken": { "type": "boolean" },
        "isDeleted": { "type": "boolean" },
        "deletedAt": { "type": ["number", "null"] },
        "form": { "type": "string", "enum": ["tablet", "capsule", "syrup", "ampule", "powder", "other"] }
      },
      "required": ["id", "name", "dosage", "expirationDate", "userId"]
    },
    "MedicineHistory": {
      "title": "MedicineHistory",
      "description": "A log of changes made to a medicine",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "medicineId": { "type": "string" },
        "userId": { "type": "string" },
        "timestamp": { "type": "number" },
        "actionType": { "type": "string", "enum": ["CREATE", "EDIT", "MARK_TAKEN", "MARK_NOT_TAKEN", "DELETE"] },
        "details": { "type": "string" }
      },
      "required": ["id", "medicineId", "userId", "timestamp", "actionType", "details"]
    },
    "UserConfig": {
      "title": "UserConfig",
      "description": "User-specific settings and preferences",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "emailNotificationsEnabled": { "type": "boolean" },
        "browserNotificationsEnabled": { "type": "boolean" },
        "alertThreshold": { "type": "number" },
        "accentColor": { "type": "string" },
        "sortOrder": { "type": "string", "enum": ["default", "asc", "desc"] },
        "lowQuantityThreshold": { "type": "number" },
        "theme": { "type": "string", "enum": ["system", "light", "dark"] }
      },
      "required": ["userId", "email"]
    },
    "ChatSession": {
      "title": "ChatSession",
      "description": "An AI chat conversation session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "number" },
        "lastMessageAt": { "type": "number" }
      },
      "required": ["id", "userId", "title", "createdAt", "lastMessageAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A message within a chat session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant", "system"] },
        "content": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["id", "role", "content", "timestamp"]
    }
  },
  "firestore": {
    "/medicines/{medicineId}": {
      "schema": "Medicine",
      "description": "Collection of medicines"
    },
    "/medicines/{medicineId}/history/{historyId}": {
      "schema": "MedicineHistory",
      "description": "Subcollection of history logs for a medicine"
    },
    "/users/{userId}/settings/appSettings": {
      "schema": "UserConfig",
      "description": "User configuration and preferences"
    },
    "/users/{userId}/chats/{sessionId}": {
      "schema": "ChatSession",
      "description": "User's AI chat sessions"
    },
    "/users/{userId}/chats/{sessionId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Messages within a chat session"
    }
  }
}
